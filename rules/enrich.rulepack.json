{
  "schema_version": "diag_enrich_rulepack/v1alpha1",
  "rulepack_version": "phase1",
  "ingress_specific_override_rule_id": "rule.family.ingress_specific_override",
  "unknown_fallback": {
    "family": "unknown",
    "rule_id": "rule.family.unknown",
    "matched_conditions": [
      "no_family_rule_matched"
    ],
    "suppression_reason": "generic_fallback"
  },
  "passthrough_fallback": {
    "family": "passthrough",
    "rule_id": "rule.family.passthrough.semantic_role",
    "matched_conditions": [
      "no_family_rule_matched"
    ],
    "suppression_reason": "generic_fallback"
  },
  "rules": [
    {
      "rule_id": "rule.family.linker.structured_or_message",
      "family": "linker",
      "phase_match": [
        "link"
      ],
      "require_any_of": [
        {
          "kind": "has_context",
          "context": "linker_resolution"
        },
        {
          "kind": "has_symbol_context"
        },
        {
          "kind": "message_terms"
        }
      ],
      "message_groups": [
        {
          "prefix": "message_contains",
          "terms": [
            "undefined reference",
            "multiple definition",
            "cannot find -l",
            "cannot find"
          ]
        }
      ],
      "contexts": [
        {
          "kind": "linker_resolution",
          "condition": "context=linker_resolution"
        }
      ],
      "symbol_context_condition": "symbol_context=present",
      "phase_annotations": []
    },
    {
      "rule_id": "rule.family.template.structured_or_message",
      "family": "template",
      "require_any_of": [
        {
          "kind": "has_context",
          "context": "template_instantiation"
        },
        {
          "kind": "has_child_note_kind",
          "child_note": "template_context"
        },
        {
          "kind": "message_terms"
        },
        {
          "kind": "child_message_terms"
        }
      ],
      "message_groups": [
        {
          "prefix": "message_contains",
          "terms": [
            "template",
            "deduction/substitution",
            "deduced conflicting"
          ]
        }
      ],
      "child_message_groups": [
        {
          "prefix": "child_message_contains",
          "terms": [
            "template",
            "deduction/substitution",
            "deduced conflicting"
          ]
        }
      ],
      "contexts": [
        {
          "kind": "template_instantiation",
          "condition": "context=template_instantiation"
        }
      ],
      "child_notes": [
        {
          "kind": "template_context",
          "condition": "child_note_kind=template_context"
        }
      ],
      "phase_annotations": [
        {
          "phase": "instantiate",
          "condition": "phase=instantiate",
          "when": "rule_matched"
        }
      ]
    },
    {
      "rule_id": "rule.family.macro_include.structured_or_message",
      "family": "macro_include",
      "require_any_of": [
        {
          "kind": "has_context",
          "context": "macro_expansion"
        },
        {
          "kind": "has_context",
          "context": "include"
        },
        {
          "kind": "has_child_note_kind",
          "child_note": "macro_expansion"
        },
        {
          "kind": "has_child_note_kind",
          "child_note": "include"
        },
        {
          "kind": "message_terms"
        },
        {
          "kind": "child_message_terms"
        }
      ],
      "message_groups": [
        {
          "prefix": "message_contains",
          "terms": [
            "macro"
          ]
        },
        {
          "prefix": "message_contains",
          "terms": [
            "include",
            "included from"
          ]
        }
      ],
      "child_message_groups": [
        {
          "prefix": "child_message_contains",
          "terms": [
            "macro"
          ]
        },
        {
          "prefix": "child_message_contains",
          "terms": [
            "include",
            "included from"
          ]
        }
      ],
      "contexts": [
        {
          "kind": "macro_expansion",
          "condition": "context=macro_expansion"
        },
        {
          "kind": "include",
          "condition": "context=include"
        }
      ],
      "child_notes": [
        {
          "kind": "macro_expansion",
          "condition": "child_note_kind=macro_expansion"
        },
        {
          "kind": "include",
          "condition": "child_note_kind=include"
        }
      ]
    },
    {
      "rule_id": "rule.family.type_overload.structured_or_message",
      "family": "type_overload",
      "require_any_of": [
        {
          "kind": "has_candidate_child"
        },
        {
          "kind": "message_terms"
        }
      ],
      "message_groups": [
        {
          "prefix": "message_contains",
          "terms": [
            "cannot convert",
            "invalid conversion",
            "no matching",
            "candidate",
            "incompatible type",
            "passing argument"
          ]
        }
      ],
      "candidate_child_terms": [
        "candidate "
      ],
      "candidate_child_condition": "child_role=candidate",
      "phase_annotations": [
        {
          "phase": "semantic",
          "condition": "phase=semantic",
          "when": "message_terms"
        },
        {
          "phase": "instantiate",
          "condition": "phase=instantiate",
          "when": "message_or_candidate"
        }
      ]
    },
    {
      "rule_id": "rule.family.syntax.phase_or_message",
      "family": "syntax",
      "require_any_of": [
        {
          "kind": "message_terms"
        }
      ],
      "message_groups": [
        {
          "prefix": "message_contains",
          "terms": [
            "expected",
            "before",
            "missing"
          ]
        }
      ],
      "phase_annotations": [
        {
          "phase": "parse",
          "condition": "phase=parse",
          "when": "rule_matched"
        }
      ]
    },
    {
      "rule_id": "rule.family.passthrough.semantic_role",
      "family": "passthrough",
      "require_any_of": [
        {
          "kind": "semantic_role_is",
          "semantic_role": "passthrough"
        }
      ],
      "semantic_role_condition": "semantic_role=passthrough"
    }
  ],
  "adapter_seed_rules": [
