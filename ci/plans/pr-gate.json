{
  "schema_version": 2,
  "workflow": "pr-gate",
  "job": "pr-gate",
  "steps": [
    {
      "id": "prepare-report-directories",
      "order": 1,
      "name": "Prepare report directories",
      "policy": "always",
      "failure_classification": "instrumentation",
      "command": "mkdir -p \"$REPORT_ROOT/replay\" \"$REPORT_ROOT/snapshot\" \"$REPORT_ROOT/self-check\" \"$REPORT_ROOT/release\" \"$TARGET_DIR\"",
      "fixture": null,
      "gcc_version": "host",
      "support_tier": "repository_gate",
      "artifact_paths": [
        "$REPORT_ROOT/replay",
        "$REPORT_ROOT/snapshot",
        "$REPORT_ROOT/self-check",
        "$REPORT_ROOT/release",
        "$REPORT_ROOT/gate"
      ]
    },
    {
      "id": "capture-host-build-environment",
      "order": 2,
      "name": "Capture host build environment",
      "policy": "always",
      "failure_classification": "infrastructure",
      "command": "python3 ci/gate_capture_environment.py --output \"$REPORT_ROOT/gate/build-environment.json\" --mode host --toolchain-file rust-toolchain.toml",
      "fixture": null,
      "gcc_version": "host",
      "support_tier": "repository_gate",
      "artifact_paths": [
        "$REPORT_ROOT/gate/build-environment.json"
      ]
    },
    {
      "id": "build-gcc15-ci-image",
      "order": 3,
      "name": "Build GCC 15 CI image",
      "policy": "always",
      "failure_classification": "infrastructure",
      "command": "docker build --build-arg GCC_IMAGE=gcc:15 -t gcc-formed-ci:pr -f ci/images/gcc-matrix/Dockerfile .",
      "fixture": null,
      "gcc_version": "gcc:15",
      "support_tier": "gcc15_primary",
      "artifact_paths": []
    },
    {
      "id": "capture-gcc15-ci-environment",
      "order": 4,
      "name": "Capture GCC 15 CI environment",
      "policy": "always",
      "failure_classification": "infrastructure",
      "command": "python3 ci/gate_capture_environment.py --output \"$REPORT_ROOT/gate/build-environment.json\" --mode ci-image --toolchain-file rust-toolchain.toml --dockerfile ci/images/gcc-matrix/Dockerfile --docker-base-image gcc:15 --docker-image-tag gcc-formed-ci:pr",
      "fixture": null,
      "gcc_version": "gcc:15",
      "support_tier": "gcc15_primary",
      "artifact_paths": [
        "$REPORT_ROOT/gate/build-environment.json"
      ]
    },
    {
      "id": "cargo-xtask-check",
      "order": 5,
      "name": "cargo xtask check",
      "policy": "always",
      "failure_classification": "product",
      "command": "cargo xtask check",
      "fixture": null,
      "gcc_version": "host",
      "support_tier": "repository_gate",
      "artifact_paths": []
    },
    {
      "id": "representative-acceptance-replay",
      "order": 6,
      "name": "Representative acceptance replay",
      "policy": "always",
      "failure_classification": "product",
      "command": "cargo xtask replay --root corpus --subset representative --report-dir \"$REPORT_ROOT/replay\"",
      "fixture": "subset:representative",
      "gcc_version": "gcc:15",
      "support_tier": "gcc15_primary",
      "artifact_paths": [
        "$REPORT_ROOT/replay",
        "$REPORT_ROOT/replay/replay-report.json"
      ]
    },
    {
      "id": "build-wrapper-binary-gcc15-image",
      "order": 7,
      "name": "Build wrapper binary in GCC 15 image",
      "policy": "always",
      "failure_classification": "product",
      "command": "docker run --rm -v \"$PWD:/workspace\" -v \"$TARGET_DIR:/tmp/gcc-formed-target\" -w /workspace gcc-formed-ci:pr bash -lc \"export CARGO_TARGET_DIR=/tmp/gcc-formed-target && cargo build --bin gcc-formed\"",
      "fixture": null,
      "gcc_version": "gcc:15",
      "support_tier": "gcc15_primary",
      "artifact_paths": []
    },
    {
      "id": "wrapper-self-check-gcc15-image",
      "order": 8,
      "name": "Wrapper self-check in GCC 15 image",
      "policy": "always",
      "failure_classification": "product",
      "command": "docker run --rm -v \"$PWD:/workspace\" -v \"$TARGET_DIR:/tmp/gcc-formed-target\" -v \"$REPORT_ROOT:/reports\" -w /workspace gcc-formed-ci:pr bash -lc \"export CARGO_TARGET_DIR=/tmp/gcc-formed-target && /tmp/gcc-formed-target/debug/gcc-formed --formed-self-check > /reports/self-check/report.json\"",
      "fixture": null,
      "gcc_version": "gcc:15",
      "support_tier": "gcc15_primary",
      "artifact_paths": [
        "$REPORT_ROOT/self-check",
        "$REPORT_ROOT/self-check/report.json"
      ]
    },
    {
      "id": "representative-gcc15-snapshot-check",
      "order": 9,
      "name": "Representative GCC 15 snapshot check",
      "policy": "always",
      "failure_classification": "product",
      "command": "cargo xtask snapshot --root corpus --subset representative --check --docker-image gcc:15 --report-dir \"$REPORT_ROOT/snapshot\"",
      "fixture": "subset:representative",
      "gcc_version": "gcc:15",
      "support_tier": "gcc15_primary",
      "artifact_paths": [
        "$REPORT_ROOT/snapshot",
        "$REPORT_ROOT/snapshot/snapshot-report.json"
      ]
    },
    {
      "id": "vendor-dependency-tree",
      "order": 10,
      "name": "Vendor dependency tree",
      "policy": "always",
      "failure_classification": "product",
      "command": "cargo xtask vendor --output-dir vendor > \"$REPORT_ROOT/release/vendor.json\"",
      "fixture": null,
      "gcc_version": "host",
      "support_tier": "repository_gate",
      "artifact_paths": [
        "$REPORT_ROOT/release/vendor.json"
      ]
    },
    {
      "id": "hermetic-release-build-smoke",
      "order": 11,
      "name": "Hermetic release build smoke",
      "policy": "always",
      "failure_classification": "product",
      "command": "cargo xtask hermetic-release-check --vendor-dir vendor --bin gcc-formed --target-triple x86_64-unknown-linux-musl > \"$REPORT_ROOT/release/hermetic-release.json\"",
      "fixture": null,
      "gcc_version": "host",
      "support_tier": "repository_gate",
      "artifact_paths": [
        "$REPORT_ROOT/release/hermetic-release.json"
      ]
    },
    {
      "id": "release-packaging-smoke",
      "order": 12,
      "name": "Release packaging smoke",
      "policy": "always",
      "failure_classification": "product",
      "command": "package signed musl artifact and write $REPORT_ROOT/release/package.json",
      "fixture": null,
      "gcc_version": "host",
      "support_tier": "repository_gate",
      "artifact_paths": [
        "$REPORT_ROOT/release/package.json",
        "dist"
      ]
    },
    {
      "id": "release-install-smoke",
      "order": 13,
      "name": "Release install smoke",
      "policy": "always",
      "failure_classification": "product",
      "command": "install packaged release, run --formed-version, and uninstall",
      "fixture": null,
      "gcc_version": "host",
      "support_tier": "repository_gate",
      "artifact_paths": [
        "$REPORT_ROOT/release/install.json",
        "$REPORT_ROOT/release/installed-version.txt",
        "$REPORT_ROOT/release/uninstall.json"
      ]
    },
    {
      "id": "rollback-symlink-smoke",
      "order": 14,
      "name": "Rollback symlink smoke",
      "policy": "always",
      "failure_classification": "product",
      "command": "cargo test -p xtask rollback_switches_current_symlink_to_requested_version > \"$REPORT_ROOT/release/rollback-smoke.txt\"",
      "fixture": null,
      "gcc_version": "host",
      "support_tier": "repository_gate",
      "artifact_paths": [
        "$REPORT_ROOT/release/rollback-smoke.txt"
      ]
    },
    {
      "id": "system-wide-layout-smoke",
      "order": 15,
      "name": "System-wide layout smoke",
      "policy": "always",
      "failure_classification": "product",
      "command": "install packaged release into pseudo-root system layout and uninstall",
      "fixture": null,
      "gcc_version": "host",
      "support_tier": "repository_gate",
      "artifact_paths": [
        "$REPORT_ROOT/release/system-install.json",
        "$REPORT_ROOT/release/system-version.txt",
        "$REPORT_ROOT/release/system-uninstall.json"
      ]
    },
    {
      "id": "release-repository-promote-and-pin-smoke",
      "order": 16,
      "name": "Release repository promote and pin smoke",
      "policy": "always",
      "failure_classification": "product",
      "command": "publish release repository, promote canary/beta, resolve beta, install exact version, and uninstall",
      "fixture": null,
      "gcc_version": "host",
      "support_tier": "repository_gate",
      "artifact_paths": [
        "$REPORT_ROOT/release/release-publish.json",
        "$REPORT_ROOT/release/release-promote-canary.json",
        "$REPORT_ROOT/release/release-promote-beta.json",
        "$REPORT_ROOT/release/release-resolve-beta.json",
        "$REPORT_ROOT/release/install-release.json",
        "$REPORT_ROOT/release/install-release-version.txt",
        "$REPORT_ROOT/release/install-release-uninstall.json"
      ]
    },
    {
      "id": "release-provenance-manifest",
      "order": 17,
      "name": "Release provenance manifest",
      "policy": "always",
      "failure_classification": "instrumentation",
      "command": "python3 release provenance manifest writer",
      "fixture": null,
      "gcc_version": "host",
      "support_tier": "repository_gate",
      "artifact_paths": [
        "$REPORT_ROOT/release/release-provenance.json"
      ]
    },
    {
      "id": "dependency-and-license-gate",
      "order": 18,
      "name": "Dependency and license gate",
      "policy": "always",
      "failure_classification": "product",
      "command": "cargo install cargo-deny --locked && cargo deny check > \"$REPORT_ROOT/release/cargo-deny.txt\"",
      "fixture": null,
      "gcc_version": "host",
      "support_tier": "repository_gate",
      "artifact_paths": [
        "$REPORT_ROOT/release/cargo-deny.txt"
      ]
    }
  ]
}
