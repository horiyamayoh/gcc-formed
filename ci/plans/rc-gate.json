{
  "schema_version": 3,
  "workflow": "rc-gate",
  "job": "rc-gate",
  "steps": [
    {
      "id": "prepare-report-directories",
      "order": 1,
      "name": "Prepare report directories",
      "policy": "always",
      "failure_classification": "instrumentation",
      "command": "mkdir -p \"$REPORT_ROOT/rc-gate\" \"$REPORT_ROOT/gate\"",
      "fixture": null,
      "gcc_version": "host",
      "artifact_paths": [
        "$REPORT_ROOT/rc-gate",
        "$REPORT_ROOT/gate"
      ],
      "gate_scope": "release_candidate"
    },
    {
      "id": "capture-host-build-environment",
      "order": 2,
      "name": "Capture host build environment",
      "policy": "always",
      "failure_classification": "infrastructure",
      "command": "python3 ci/gate_capture_environment.py --output \"$REPORT_ROOT/gate/build-environment.json\" --mode host --toolchain-file rust-toolchain.toml",
      "fixture": null,
      "gcc_version": "host",
      "artifact_paths": [
        "$REPORT_ROOT/gate/build-environment.json"
      ],
      "gate_scope": "release_candidate"
    },
    {
      "id": "cargo-xtask-rc-gate",
      "order": 3,
      "name": "cargo xtask rc-gate",
      "policy": "always",
      "failure_classification": "product",
      "command": "cargo xtask rc-gate --root corpus --report-dir \"$REPORT_ROOT/rc-gate\" --agent-output-quality-report eval/output-quality-single-agent-v2/evidence/qualification-report.json --metrics-manual-report eval/rc/metrics-manual-eval.json --issue-budget-report eval/rc/issue-budget.json --fuzz-root fuzz --ux-signoff-report eval/rc/ux-signoff.json",
      "fixture": "subset:all",
      "gcc_version": "host",
      "artifact_paths": [
        "$REPORT_ROOT/rc-gate",
        "$REPORT_ROOT/rc-gate/replay-report.json",
        "$REPORT_ROOT/rc-gate/native-parity-report.json",
        "$REPORT_ROOT/rc-gate/bench-smoke-report.json",
        "$REPORT_ROOT/rc-gate/deterministic-replay-report.json",
        "$REPORT_ROOT/rc-gate/rollout-matrix-report.json",
        "$REPORT_ROOT/rc-gate/agent-output-quality",
        "$REPORT_ROOT/rc-gate/agent-output-quality/qualification-report.json",
        "$REPORT_ROOT/rc-gate/agent-output-quality/validation-report.json",
        "$REPORT_ROOT/rc-gate/fuzz-smoke-report.json",
        "$REPORT_ROOT/rc-gate/fuzz-evidence.json",
        "$REPORT_ROOT/rc-gate/metrics-report.json",
        "$REPORT_ROOT/rc-gate/metrics-manual-eval.json",
        "$REPORT_ROOT/rc-gate/rc-gate-report.json",
        "$REPORT_ROOT/rc-gate/rc-gate-summary.md"
      ],
      "gate_scope": "release_candidate"
    },
    {
      "id": "path-aware-replay-stop-ship",
      "order": 4,
      "name": "Replay stop-ship contract",
      "policy": "always",
      "failure_classification": "product",
      "command": "python3 ci/parity_gap_report.py --root corpus --output \"$REPORT_ROOT/gate/parity-gaps.json\" && python3 ci/gate_replay_contract.py --replay-report \"$REPORT_ROOT/rc-gate/replay-report.json\" --output \"$REPORT_ROOT/gate/replay-stop-ship.json\"",
      "fixture": "subset:all",
      "gcc_version": "host",
      "artifact_paths": [
        "$REPORT_ROOT/gate/replay-stop-ship.json"
      ],
      "gate_scope": "release_candidate"
    },
    {
      "id": "repair-unit-quality-gate",
      "order": 5,
      "name": "RepairUnit release exact-count quality gate",
      "policy": "always",
      "failure_classification": "product",
      "command": "cargo xtask repair-oracle --root corpus --check && cargo xtask quality-report --root corpus --format json > \"$REPORT_ROOT/gate/repair-unit-quality.json\" && cargo xtask real-project-corpus verify > \"$REPORT_ROOT/gate/real-project-readiness.json\" && cargo xtask repair-oracle --root corpus/real-project --check && cargo xtask quality-report --root corpus/real-project --format json > \"$REPORT_ROOT/gate/real-project-quality.json\"",
      "fixture": "repair-oracle:all",
      "gcc_version": "host",
      "artifact_paths": ["$REPORT_ROOT/gate/repair-unit-quality.json", "$REPORT_ROOT/gate/real-project-readiness.json", "$REPORT_ROOT/gate/real-project-quality.json"],
      "gate_scope": "release_candidate"
    },
    {
      "id": "output-quality-candidate-matrix",
      "order": 6,
      "name": "Output-quality candidate GCC/path matrix",
      "policy": "always",
      "failure_classification": "product",
      "command": "cargo xtask output-quality-matrix --root corpus --output \"$REPORT_ROOT/gate/human-readable-contract-matrix.json\"",
      "fixture": "candidate:repair_units_hybrid_v2",
      "gcc_version": "retained-real-compiler-matrix",
      "artifact_paths": [
        "$REPORT_ROOT/gate/human-readable-contract-matrix.json"
      ],
      "gate_scope": "release_candidate"
    }
  ]
}
