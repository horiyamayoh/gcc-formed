{
  "docs_only_globs": [
    "docs/**",
    "*.md",
    "*.rst",
    "*.txt",
    "*.adoc",
    "LICENSE",
    "NOTICE"
  ],
  "never_docs_only_globs": [
    ".github/workflows/**",
    ".github/ISSUE_TEMPLATE/**",
    "**/*.rs",
    "xtask/**",
    "config/**",
    "corpus/**",
    "rules/**",
    "Cargo.toml",
    "Cargo.lock",
    "deny.toml",
    "rust-toolchain.toml",
    "clippy.toml",
    ".rustfmt.toml"
  ],
  "evidence": {
    "required_files": [
      {
        "path": ".codex/evidence/work-plan.md",
        "headings": [
          "# Work plan",
          "## Goal",
          "## Non-goals",
          "## Allowed files",
          "## Forbidden surfaces",
          "## Risks",
          "## Validation plan",
          "## Sync obligations",
          "## Stop conditions"
        ]
      },
      {
        "path": ".codex/evidence/self-review.md",
        "headings": [
          "# Self-review",
          "## Diff audit",
          "## Contract audit",
          "## Edge cases checked",
          "## Commands run",
          "## Docs / ADR / changelog",
          "## Remaining risks"
        ]
      }
    ]
  },
  "sync_rules": [
    {
      "name": "support-boundary-sync",
      "severity": "error",
      "when_any_changed": [
        "docs/support/SUPPORT-BOUNDARY.md"
      ],
      "require_changed_all": [
        "README.md"
      ],
      "require_changed_any": [
        ".github/pull_request_template.md",
        ".github/ISSUE_TEMPLATE/**"
      ],
      "message": "Support-boundary changes must also update README and at least one GitHub template."
    },
    {
      "name": "public-export-runtime-and-spec",
      "severity": "error",
      "when_any_changed": [
        "diag_public_export/**",
        "docs/specs/public-machine-readable-diagnostic-surface-spec.md"
      ],
      "require_changed_all": [
        "docs/specs/public-machine-readable-diagnostic-surface-spec.md"
      ],
      "require_changed_any": [
        "diag_public_export/**"
      ],
      "message": "Public machine-readable export changes must update both runtime and spec."
    },
    {
      "name": "support-routing-sync",
      "severity": "warn",
      "when_any_changed": [
        "SUPPORT.md",
        "docs/runbooks/**",
        ".github/ISSUE_TEMPLATE/bug_report.yml"
      ],
      "require_changed_any": [
        "SUPPORT.md",
        "docs/runbooks/**",
        ".github/ISSUE_TEMPLATE/bug_report.yml"
      ],
      "message": "Support-routing changes should keep SUPPORT.md, runbooks, and bug-report template aligned."
    },
    {
      "name": "public-surface-sync",
      "severity": "warn",
      "when_any_changed": [
        "README.md",
        "docs/support/PUBLIC-SURFACE.md"
      ],
      "require_changed_any": [
        "README.md",
        "docs/support/PUBLIC-SURFACE.md"
      ],
      "message": "Landing-copy changes should keep README and PUBLIC-SURFACE aligned."
    },
    {
      "name": "release-automation-sync",
      "severity": "warn",
      "when_any_changed": [
        "xtask/**",
        ".github/workflows/release*.yml",
        "docs/releases/**"
      ],
      "require_changed_any": [
        "docs/releases/**",
        ".github/workflows/**",
        "xtask/**"
      ],
      "message": "Release automation changes should keep xtask, release docs, and workflows aligned."
    }
  ],
  "workflow_lint_commands": [
    "actionlint"
  ]
}
